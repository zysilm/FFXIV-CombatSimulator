<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <Version>2.1.0.6</Version>
    <Authors>zysilm</Authors>
    <Description>Client-side party combat simulation with NPCs and field enemies</Description>
    <IsPackable>false</IsPackable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="BepuPhysics" Version="2.5.0-beta.22" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Npcs\NpcNames.json" />
    <EmbeddedResource Include="Resources\BuiltInBoneProfiles.json" />
    <EmbeddedResource Include="Resources\CombatRecipes\*.json" />
    <EmbeddedResource Include="Resources\ActionPotencies.json" />
  </ItemGroup>
</Project>
